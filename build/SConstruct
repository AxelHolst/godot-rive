#!/usr/bin/env python
from os.path import join


def GetRiveBin(path: str) -> str:
    """Get path to rive-runtime binary library."""
    platform_map = {
        "macos": "macosx",
        "windows": "windows",
    }
    target_map = {
        "template_debug": "debug",
        "template_release": "release",
    }
    return File(
        join(
            "../thirdparty/rive-runtime",
            path.format(
                platform=platform_map.get(env["platform"], env["platform"]),
                target=target_map.get(env["target"], env["target"]),
                suffix=env.get("LIBSUFFIX", ".a"),
            ),
        )
    )


SConscript("SConscript.common")
env = SConscript("../godot-cpp/SConstruct")

env["STATIC_AND_SHARED_OBJECTS_ARE_THE_SAME"] = True

# =============================================================================
# CRITICAL: Preprocessor defines MUST match librive.a build exactly!
# These defines affect class memory layout (conditional member variables).
# Mismatch causes ABI incompatibility: wrong struct sizes, offset errors.
# Reference: thirdparty/rive-runtime/out/debug/rive.make
# =============================================================================
env.Append(CPPDEFINES=[
    "WITH_RIVE_TEXT",      # Enables text rendering support
    "WITH_RIVE_LAYOUT",    # Enables Yoga layout engine
    "RIVE_MACOSX",         # Platform identifier (macOS builds)
    ("YOGA_EXPORT", ""),   # Empty define for Yoga export macro
    "_RIVE_INTERNAL_",     # Internal Rive APIs
])

# NOTE: DEBUG/NDEBUG handling
# - godot-cpp already defines NDEBUG for non-dev builds (including template_debug)
# - rive_types.hpp will auto-set DEBUG=1 if NDEBUG is not defined
# - We do NOT manually set DEBUG to avoid conflict with godot-cpp's NDEBUG
# For debug librive.a linking, the rive-runtime was built with DEBUG, but
# ABI compatibility depends on struct layout defines (WITH_RIVE_*), not DEBUG/NDEBUG

# Exception handling: Match librive.a build settings
# librive.a is built with -fno-exceptions, but we need exceptions for Godot/GDExtension
# RTTI is required for dynamic_cast in our wrapper code
env.Append(CXXFLAGS=["-fexceptions", "-frtti"])
env.Append(CFLAGS=["-fexceptions"])

sources = []

# rive-runtime root directory
RIVE_RUNTIME_DIR = "../thirdparty/rive-runtime"

# =============================================================================
# CRITICAL: Force-include headers for symbol renaming
# These MUST be included before any Rive/HarfBuzz/Yoga headers to rename symbols
# and avoid ODR violations. Matches: rive.make FORCE_INCLUDE directive.
# =============================================================================
RIVE_DEPS_DIR = join(RIVE_RUNTIME_DIR, "dependencies")
env.Append(CXXFLAGS=[
    "-include", join(RIVE_DEPS_DIR, "rive_harfbuzz_renames.h"),
    "-include", join(RIVE_DEPS_DIR, "rive_yoga_renames.h"),
])
env.Append(CFLAGS=[
    "-include", join(RIVE_DEPS_DIR, "rive_harfbuzz_renames.h"),
    "-include", join(RIVE_DEPS_DIR, "rive_yoga_renames.h"),
])

# =============================================================================
# macOS-specific flags to match librive.a build exactly
# Reference: thirdparty/rive-runtime/out/debug/rive.make ALL_CXXFLAGS
# =============================================================================
if env.get("platform") == "macos":
    # Objective-C ARC (Automatic Reference Counting) - required for Apple frameworks
    env.Append(CXXFLAGS=["-fobjc-arc"])
    env.Append(CFLAGS=["-fobjc-arc"])
    # macOS deployment target - must match librive.a build
    env.Append(CXXFLAGS=["-mmacosx-version-min=11.0"])
    env.Append(CFLAGS=["-mmacosx-version-min=11.0"])
    env.Append(LINKFLAGS=["-mmacosx-version-min=11.0"])

# Add skia library
SKIA_SRC_DIR = join(RIVE_RUNTIME_DIR, "skia/dependencies/skia")
env.RequireFile(Dir(SKIA_SRC_DIR))

# Determine Skia output directory based on platform and architecture
if env["platform"] == "macos":
    skia_out_dir = join(SKIA_SRC_DIR, "out/macosx/x64")
    # Fix for macOS Command Line Tools: add explicit C++ include path
    env.Append(CXXFLAGS=["-I/Library/Developer/CommandLineTools/SDKs/MacOSX.sdk/usr/include/c++/v1"])
    # Link required Apple frameworks for HarfBuzz CoreText support and Skia image encoding
    env.Append(LINKFLAGS=[
        "-framework", "CoreText",
        "-framework", "CoreGraphics",
        "-framework", "CoreFoundation",
        "-framework", "CoreServices",  # For kUTType* symbols used by Skia image encoders
        "-framework", "Metal",  # Skia Metal backend
        "-framework", "Foundation",  # Foundation for Objective-C runtime
        "-framework", "ImageIO",  # For kCGImageProperty* symbols
    ])
    # Remove dead_strip and stripping flags to preserve Skia symbols
    # -dead_strip: removes unused code sections
    # -S: strip debug symbols
    # -x: strip local symbols
    strip_flags = ["-Wl,-dead_strip", "-Wl,-S", "-Wl,-x"]
    env["LINKFLAGS"] = [f for f in env["LINKFLAGS"] if f not in strip_flags]
elif env["platform"] == "windows":
    skia_out_dir = join(SKIA_SRC_DIR, "out/windows/x64")
else:
    skia_out_dir = join(SKIA_SRC_DIR, "out/static")

# Add Skia library with force_load to ensure all symbols (including vtables) are preserved
import os
skia_lib_path = os.path.abspath(join(skia_out_dir, "libskia.a"))
# Use -force_load to pull in all object files from libskia.a
env.Prepend(
    LINKFLAGS=["-Wl,-force_load," + skia_lib_path],
)

env.Prepend(
    LIBPATH=[skia_out_dir],
    CPPPATH=[
        SKIA_SRC_DIR,
        join(SKIA_SRC_DIR, "include"),
        join(SKIA_SRC_DIR, "src"),
    ],
)

# Add rive-runtime libraries
# Note: Build output paths may vary - these are the expected locations after build
rive_bins = [
    GetRiveBin("out/{target}/librive{suffix}"),
    GetRiveBin("skia/renderer/out/{target}/librive_skia_renderer{suffix}"),
    GetRiveBin("out/{target}/librive_harfbuzz{suffix}"),
    GetRiveBin("out/{target}/librive_sheenbidi{suffix}"),
    GetRiveBin("out/{target}/librive_yoga{suffix}"),
]

for lib in rive_bins:
    env.RequireFile(lib)

# Link rive libraries normally (not with force_load since they have undefined symbol refs)
env.Prepend(
    LIBS=rive_bins,
    CPPPATH=[
        RIVE_RUNTIME_DIR,
        join(RIVE_RUNTIME_DIR, "include"),
        join(RIVE_RUNTIME_DIR, "src"),
        join(RIVE_RUNTIME_DIR, "skia/renderer"),
        join(RIVE_RUNTIME_DIR, "skia/renderer/include"),
        join(RIVE_RUNTIME_DIR, "skia/renderer/src"),
    ],
)

# Add source files
env.Append(CPPPATH=["../src/"])
sources += env.GlobRecursive("../src", "*.cpp")

if env["platform"] == "macos":
    library = env.SharedLibrary(
        "../demo/bin/librive.{}.{}.framework/librive.{}.{}".format(
            env["platform"], env["target"], env["platform"], env["target"]
        ),
        source=sources,
    )
else:
    library = env.SharedLibrary(
        "../demo/bin/librive{}{}".format(env["suffix"], env["SHLIBSUFFIX"]),
        source=sources,
    )

Default(library)
