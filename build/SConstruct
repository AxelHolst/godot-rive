#!/usr/bin/env python
from os.path import join
import os

SConscript("SConscript.common")
env = SConscript("../godot-cpp/SConstruct")

env["STATIC_AND_SHARED_OBJECTS_ARE_THE_SAME"] = True

# This library uses exceptions, so remove the no exceptions flag
if "-fno-exceptions" in env["CXXFLAGS"]:
    env["CXXFLAGS"].remove("-fno-exceptions")

sources = []

# Add rive library
env.Append(CXXFLAGS=["-frtti"])
RIVE_SRC_DIR = "../thirdparty/rive-cpp/"
RIVE_LIB_DIR = os.path.abspath(join(RIVE_SRC_DIR, "renderer/out/release"))
rive_bins = [
    join(RIVE_SRC_DIR, "renderer/out/release/librive.a"),
    join(RIVE_SRC_DIR, "renderer/out/release/librive_pls_renderer.a"),
    join(RIVE_SRC_DIR, "renderer/out/release/librive_decoders.a"),
    join(RIVE_SRC_DIR, "renderer/out/release/librive_yoga.a"),
    join(RIVE_SRC_DIR, "renderer/out/release/librive_sheenbidi.a"),
    join(RIVE_SRC_DIR, "renderer/out/release/librive_harfbuzz.a"),
]
env.Prepend(
    CPPPATH=[
        RIVE_SRC_DIR,
        join(RIVE_SRC_DIR, "include"),
        join(RIVE_SRC_DIR, "src"),
        join(RIVE_SRC_DIR, "renderer"),
        join(RIVE_SRC_DIR, "renderer/include"),
        join(RIVE_SRC_DIR, "renderer/src"),
        join(RIVE_SRC_DIR, "renderer/glad"),
        join(RIVE_SRC_DIR, "decoders"),
        join(RIVE_SRC_DIR, "decoders/include"),
        join(RIVE_SRC_DIR, "decoders/src"),
    ],
)
env.Append(LIBPATH=[join(RIVE_SRC_DIR, "renderer/out/release")])
env.Append(LIBPATH=[RIVE_LIB_DIR])
if env["platform"] == "macos":
    env.Append(
        LINKFLAGS=[
            "-all_load",
            join(RIVE_LIB_DIR, "librive.a"),
            join(RIVE_LIB_DIR, "librive_pls_renderer.a"),
            join(RIVE_LIB_DIR, "librive_decoders.a"),
            join(RIVE_LIB_DIR, "librive_yoga.a"),
            join(RIVE_LIB_DIR, "librive_sheenbidi.a"),
        ]
    )
    env.Append(LINKFLAGS=["-force_load", join(RIVE_LIB_DIR, "librive_harfbuzz.a")])
else:
    env.Append(
        LINKFLAGS=[
            "-Wl,--whole-archive",
            join(RIVE_LIB_DIR, "librive.a"),
            join(RIVE_LIB_DIR, "librive_pls_renderer.a"),
            join(RIVE_LIB_DIR, "librive_decoders.a"),
            join(RIVE_LIB_DIR, "librive_yoga.a"),
            join(RIVE_LIB_DIR, "librive_sheenbidi.a"),
            join(RIVE_LIB_DIR, "librive_harfbuzz.a"),
            "-Wl,--no-whole-archive",
        ]
    )


# Add source files
env.Append(CPPPATH=["../src/"])
sources += env.GlobRecursive("../src", "*.cpp")

if env["platform"] == "macos":
    library = env.SharedLibrary(
        "../demo/bin/librive.{}.{}.framework/librive.{}.{}".format(
            env["platform"], env["target"], env["platform"], env["target"]
        ),
        source=sources,
    )
else:
    library = env.SharedLibrary(
        "../demo/bin/librive{}{}".format(env["suffix"], env["SHLIBSUFFIX"]),
        source=sources,
    )

Default(library)
